APP_NAME=Trade Automation MVP
APP_ENV=development
API_PREFIX=/api/v1
LOG_LEVEL=INFO
JSON_LOGS=true
DATABASE_URL=postgresql+psycopg://trader:trader@postgres:5432/trading
REDIS_URL=redis://redis:6379/0
EXCHANGE_NAME=kraken
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSWORD=
DEFAULT_QUOTE_CURRENCY=USDT
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false
KILL_SWITCH=false
PAPER_STARTING_BALANCE=100000
MAX_RISK_PER_TRADE=0.01
MAX_POSITION_NOTIONAL_PCT=0.20
MAX_CONCURRENT_POSITIONS=3
MAX_DAILY_LOSS_PCT=0.03
MAX_DRAWDOWN_PCT=0.10
MAX_SPREAD_BPS=25
MAX_SLIPPAGE_BPS=20
DEFAULT_FEE_BPS=10
DEFAULT_SLIPPAGE_BPS=5
STOP_LOSS_COOLDOWN_MINUTES=30
SYMBOL_ALLOWLIST=BTC/USDT,ETH/USDT,SOL/USDT
ALLOWED_WEEKDAYS=0,1,2,3,4,5,6
SESSION_START_UTC=00:00
SESSION_END_UTC=23:59
AUTO_CREATE_TABLES=true
SCHEDULER_ENABLED=false
MARKET_REFRESH_SECONDS=60
SIGNAL_EVALUATION_SECONDS=60
DEFAULT_TIMEFRAMES=1m,5m,15m
LLM_FEATURES_ENABLED=false
OPENAI_API_KEY=
CLAUDE_API_KEY=
